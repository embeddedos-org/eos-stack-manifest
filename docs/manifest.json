            { "platform": "ESP32", "file": "eos-1.2.0-esp32.bin", "url": "https://github.com/embeddedos-org/eos/releases/download/v1.2.0/eos-1.2.0-esp32.bin", "size": "128 KB", "sha256": "f6a1b2c3d4e5..." },
