{
  "$schema": "https://embeddedos.org/manifest-schema/v1.json",
  "name": "EmbeddedOS Foundation",
  "version": "1.2.0",
  "releaseDate": "2026-05-27",
  "organization": "embeddedos-org",
  "license": "Apache-2.0",
  "nonprofit": true,
  "taxId": "501(c)(3)",
  "description": "Unified build chain manifest for the EmbeddedOS platform — from silicon to app store.",
  "buildChain": {
    "stages": [
      {
        "id": "stage-1-build",
        "name": "Build System",
        "order": 1,
        "color": "#6366f1",
        "icon": "⚙️",
        "description": "Cross-compilation toolchain, build scripts, and CI/CD pipeline for all EmbeddedOS targets.",
        "repos": ["ebuild"]
      },
      {
        "id": "stage-2-boot",
        "name": "Bootloader",
        "order": 2,
        "color": "#8b5cf6",
        "icon": "🔌",
        "description": "Secure bootloader with verified boot, OTA update support, and multi-board HAL initialization.",
        "repos": ["eBoot"]
      },
      {
        "id": "stage-3-os",
        "name": "OS Kernel",
        "order": 3,
        "color": "#06b6d4",
        "icon": "🧠",
        "description": "EoS RTOS — preemptive real-time kernel with task scheduler, memory manager, and device drivers.",
        "repos": ["eos"]
      },
      {
        "id": "stage-4-layers",
        "name": "Middleware Layers",
        "order": 4,
        "color": "#10b981",
        "icon": "📦",
        "description": "Networking, IPC, AI inference, database, and simulation middleware layers.",
        "repos": ["eNI", "eIPC", "eAI", "eDB", "EoSim", "eosllm"]
      },
      {
        "id": "stage-5-hardware",
        "name": "Hardware & CAD",
        "order": 5,
        "color": "#f59e0b",
        "icon": "🔧",
        "description": "PCB schematics, enclosure CAD, BOM, and manufacturing files for EmbeddedOS hardware.",
        "repos": ["eCAD-Hardware-Products", "eFab"]
      },
      {
        "id": "stage-6-desktop",
        "name": "Desktop Applications",
        "order": 6,
        "color": "#ec4899",
        "icon": "🖥️",
        "description": "Full-featured desktop applications built on the EmbeddedOS platform.",
        "repos": ["EoStudio", "eOffice", "eBrowser", "eVera"]
      },
      {
        "id": "stage-7-health",
        "name": "Health & Wearables",
        "order": 7,
        "color": "#ef4444",
        "icon": "❤️",
        "description": "Medical-grade health monitoring, wearable firmware, and clinical data platforms.",
        "repos": ["HealthKey-Ulta", "HEALTH-BAND-Neuro"]
      },
      {
        "id": "stage-8-apps",
        "name": "Web & Mobile Apps",
        "order": 8,
        "color": "#3b82f6",
        "icon": "📱",
        "description": "Cross-platform web and mobile applications for end users.",
        "repos": ["eApps", "eVera", "eBrowser"]
      },
      {
        "id": "stage-9-web",
        "name": "Foundation Web",
        "order": 9,
        "color": "#64748b",
        "icon": "🌐",
        "description": "EmbeddedOS Foundation website, documentation portal, and community hub.",
        "repos": ["embeddedos-org", "embeddedos-org.github.io", "www.embeddedos.org"]
      }
    ]
  },
  "projects": [
    {
      "id": "ebuild",
      "name": "eBuild",
      "repo": "embeddedos-org/ebuild",
      "stage": 1,
      "version": "1.2.0",
      "description": "Cross-compilation toolchain and build system for all EmbeddedOS targets. Supports GCC, Clang, LLVM, and custom toolchains for ARM Cortex-M/A, RISC-V, x86_64, and ESP32.",
      "tagline": "Build once, run everywhere — from microcontrollers to servers.",
      "category": "Build System",
      "competitors": ["CMake", "Bazel", "Yocto Project", "Buildroot"],
      "platforms": ["Linux", "macOS", "Windows"],
      "languages": ["Python", "CMake", "Shell", "Makefile"],
      "dependencies": [],
      "dependents": ["eBoot", "eos", "eNI", "eIPC", "eAI", "eDB", "EoSim"],
      "targets": [
        { "arch": "arm-cortex-m4", "board": "STM32F4", "toolchain": "arm-none-eabi-gcc" },
        { "arch": "arm-cortex-a53", "board": "Raspberry Pi 4", "toolchain": "aarch64-linux-gnu-gcc" },
        { "arch": "riscv32", "board": "ESP32-C3", "toolchain": "riscv32-esp-elf-gcc" },
        { "arch": "x86_64", "board": "Generic PC", "toolchain": "gcc" },
        { "arch": "xtensa-lx6", "board": "ESP32", "toolchain": "xtensa-esp32-elf-gcc" }
      ],
      "releases": {
        "v1.2.0": {
          "date": "2026-05-27",
          "notes": "Added RISC-V support, improved incremental builds, Docker-based reproducible builds, GitHub Actions integration.",
          "binaries": [
            { "platform": "Linux x86_64", "file": "ebuild-1.2.0-linux-x86_64.tar.gz", "url": "https://github.com/embeddedos-org/ebuild/releases/download/v1.2.0/ebuild-1.2.0-linux-x86_64.tar.gz", "size": "12.4 MB", "sha256": "a1b2c3d4e5f6..." },
            { "platform": "Linux ARM64", "file": "ebuild-1.2.0-linux-arm64.tar.gz", "url": "https://github.com/embeddedos-org/ebuild/releases/download/v1.2.0/ebuild-1.2.0-linux-arm64.tar.gz", "size": "11.8 MB", "sha256": "b2c3d4e5f6a1..." },
            { "platform": "macOS", "file": "ebuild-1.2.0-macos-universal.dmg", "url": "https://github.com/embeddedos-org/ebuild/releases/download/v1.2.0/ebuild-1.2.0-macos-universal.dmg", "size": "18.2 MB", "sha256": "c3d4e5f6a1b2..." },
            { "platform": "Windows", "file": "ebuild-1.2.0-windows-x64.msi", "url": "https://github.com/embeddedos-org/ebuild/releases/download/v1.2.0/ebuild-1.2.0-windows-x64.msi", "size": "22.1 MB", "sha256": "d4e5f6a1b2c3..." }
          ]
        }
      },
      "books": [
        { "title": "eBuild Developer Guide", "type": "PDF", "url": "https://github.com/embeddedos-org/ebuild/releases/download/v1.2.0/ebuild-developer-guide-v1.2.0.pdf", "pages": 142, "description": "Complete guide to configuring, extending, and using eBuild for all supported targets." },
        { "title": "Cross-Compilation Handbook", "type": "PDF", "url": "https://github.com/embeddedos-org/ebuild/releases/download/v1.2.0/cross-compilation-handbook.pdf", "pages": 89, "description": "Step-by-step cross-compilation for ARM, RISC-V, and Xtensa architectures." }
      ]
    },
    {
      "id": "eBoot",
      "name": "eBoot",
      "repo": "embeddedos-org/eBoot",
      "stage": 2,
      "version": "1.2.0",
      "description": "Secure bootloader with verified boot chain, OTA firmware updates, A/B partition support, and hardware security module integration.",
      "tagline": "Secure, fast, and field-updatable bootloader for embedded systems.",
      "category": "Bootloader",
      "competitors": ["U-Boot", "MCUboot", "TF-A", "GRUB"],
