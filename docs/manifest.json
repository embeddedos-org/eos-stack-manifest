            { "platform": "ESP32 (Xtensa)", "file": "eboot-1.2.0-esp32.bin", "url": "https://github.com/embeddedos-org/eBoot/releases/download/v1.2.0/eboot-1.2.0-esp32.bin", "size": "32 KB", "sha256": "a1b2c3d4e5f6..." },
            { "platform": "RISC-V (SiFive)", "file": "eboot-1.2.0-riscv.elf", "url": "https://github.com/embeddedos-org/eBoot/releases/download/v1.2.0/eboot-1.2.0-riscv.elf", "size": "64 KB", "sha256": "b2c3d4e5f6a1..." }
          ]
        }
