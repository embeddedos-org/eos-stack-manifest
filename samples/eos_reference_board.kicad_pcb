(kicad_pcb (version 20221018) (generator pcbnew)
  (general
    (thickness 1.6)
    (drawings 4)
    (tracks 128)
    (zones 2)
    (modules 24)
    (nets 38)
  )
  (page "A4")
  (title_block
    (title "EoS Reference Board v1.0")
    (date "2026-05-28")
    (rev "1.0")
    (company "EmbeddedOS Foundation")
    (comment 1 "Target: ARM Cortex-A57 (QEMU virt compatible)")
    (comment 2 "Memory: 512 MB LPDDR4 @ 0x40000000")
    (comment 3 "Flash: 64 MB NOR @ 0x00000000")
    (comment 4 "UART0: PL011 @ 0x09000000")
  )
  (layers
    (0 "F.Cu" signal)
    (31 "B.Cu" signal)
    (32 "B.Adhes" user)
    (33 "F.Adhes" user)
    (34 "B.Paste" user)
    (35 "F.Paste" user)
    (36 "B.SilkS" user)
    (37 "F.SilkS" user)
    (38 "B.Mask" user)
    (39 "F.Mask" user)
    (40 "Dwgs.User" user)
    (44 "Edge.Cuts" user)
  )
  (setup
    (pad_to_mask_clearance 0.051)
    (pcbplotparams
      (layerselection 0x00010fc_ffffffff)
      (outputdirectory "gerbers/")
    )
  )
  ; ── Memory map annotations (parsed by ebuild CAD pipeline) ──────────────────
  ; Format: (eos_mmap <region_name> <base_hex> <size_hex> <type>)
  ; These are embedded as KiCad user comments in the schematic annotation layer
  (eos_mmap "FLASH_NOR"    "0x00000000" "0x04000000" "rx")
  (eos_mmap "SRAM_BOOT"    "0x20000000" "0x00010000" "rwx")
  (eos_mmap "PERIPH_BASE"  "0x08000000" "0x02000000" "rw")
  (eos_mmap "UART0_PL011"  "0x09000000" "0x00001000" "rw")
  (eos_mmap "WDT_SP805"    "0x10000000" "0x00001000" "rw")
  (eos_mmap "GIC_DIST"     "0x08000000" "0x00010000" "rw")
  (eos_mmap "GIC_CPU"      "0x08010000" "0x00010000" "rw")
  (eos_mmap "RAM_LPDDR4"   "0x40000000" "0x20000000" "rwx")
  (eos_mmap "HEAP_REGION"  "0x48000000" "0x02000000" "rw")
  (eos_mmap "OTA_SCRATCH"  "0x50000000" "0x00010000" "rw")
  (eos_mmap "FRAMEBUFFER"  "0x3C000000" "0x00800000" "rw")
  ; ── CPU / SoC definition ─────────────────────────────────────────────────────
  (eos_cpu
    (arch "aarch64")
    (core "cortex-a57")
    (freq_mhz 1000)
    (endian "little")
    (fpu "neon-fp-armv8")
    (stack_size "0x00010000")
    (entry_symbol "eos_kernel_entry")
    (boot_symbol "_start")
  )
  ; ── Peripheral map (for device tree generation) ──────────────────────────────
  (eos_peripheral (name "uart0")   (compatible "arm,pl011")      (base "0x09000000") (irq 33))
  (eos_peripheral (name "wdt0")    (compatible "arm,sp805")      (base "0x10000000") (irq 32))
  (eos_peripheral (name "gic")     (compatible "arm,gic-400")    (base "0x08000000") (irq -1))
  (eos_peripheral (name "rtc0")    (compatible "arm,pl031")      (base "0x09010000") (irq 34))
  (eos_peripheral (name "spi0")    (compatible "arm,pl022")      (base "0x09020000") (irq 35))
  (eos_peripheral (name "i2c0")    (compatible "arm,versatile-i2c") (base "0x09030000") (irq 36))
  (eos_peripheral (name "eth0")    (compatible "smsc,lan9118")   (base "0x0A000000") (irq 37))
  (eos_peripheral (name "fb0")     (compatible "arm,pl111")      (base "0x3C000000") (irq 38))
  ; ── PCB components (standard KiCad footprints) ───────────────────────────────
  (module "CPU_SoC" (at 100 100)
    (fp_text reference "U1" (at 0 -3) (layer "F.SilkS") (effects (font (size 1 1))))
    (fp_text value "ARM-Cortex-A57-SoC" (at 0 3) (layer "F.SilkS") (effects (font (size 1 1))))
  )
  (module "LPDDR4_512MB" (at 150 100)
    (fp_text reference "U2" (at 0 -3) (layer "F.SilkS") (effects (font (size 1 1))))
    (fp_text value "LPDDR4-512MB" (at 0 3) (layer "F.SilkS") (effects (font (size 1 1))))
  )
  (module "NOR_FLASH_64MB" (at 200 100)
    (fp_text reference "U3" (at 0 -3) (layer "F.SilkS") (effects (font (size 1 1))))
    (fp_text value "NOR-Flash-64MB" (at 0 3) (layer "F.SilkS") (effects (font (size 1 1))))
  )
  (module "UART_CONNECTOR" (at 100 150)
    (fp_text reference "J1" (at 0 -3) (layer "F.SilkS") (effects (font (size 1 1))))
    (fp_text value "UART0-Debug" (at 0 3) (layer "F.SilkS") (effects (font (size 1 1))))
  )
)
